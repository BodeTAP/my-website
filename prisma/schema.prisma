generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js required tables ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  client   Client?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Content ──────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())

  articles Article[]

  @@map("categories")
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String        @db.Text
  coverImage  String?
  metaTitle   String?
  metaDesc    String?
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  categoryId  String?
  tags        String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("articles")
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  beforeImage String?
  afterImage  String?
  clientName  String?
  techStack   String[]
  liveUrl     String?
  metrics     String?
  order       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("portfolios")
}

// ─── Onboarding ───────────────────────────────────────────────────────────────

model OnboardingForm {
  id        String           @id @default(cuid())
  clientId  String?
  token     String           @unique @default(cuid())
  status    OnboardingStatus @default(PENDING)

  // Step 1 — Bisnis
  businessName    String?
  industryType    String?
  businessDesc    String?  @db.Text
  targetAudience  String?

  // Step 2 — Website
  websiteType     String?
  referenceUrls   String[]
  featuresWanted  String[]
  colorStyle      String?

  // Step 3 — Aset
  logoUrl         String?
  driveLink       String?
  instagram       String?
  facebook        String?
  tiktok          String?
  hasDomain       Boolean  @default(false)
  domainName      String?

  // Step 4 — Timeline
  deadline        DateTime?
  notes           String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@map("onboarding_forms")
}

// ─── Maintenance & Retainer ───────────────────────────────────────────────────

model MaintenancePackage {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int
  features    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("maintenance_packages")
}

model Subscription {
  id              String             @id @default(cuid())
  clientId        String
  packageId       String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime           @default(now())
  nextBillingDate DateTime
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  client  Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  package MaintenancePackage @relation(fields: [packageId], references: [id])

  @@map("subscriptions")
}

// ─── Site Content ─────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  business  String
  text      String   @db.Text
  rating    Int      @default(5)
  order     Int      @default(0)
  featured  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt

  @@map("site_settings")
}

// ─── Leads / CRM ──────────────────────────────────────────────────────────────

model Lead {
  id             String     @id @default(cuid())
  name           String
  businessName   String
  whatsapp       String
  domain         String?
  currentWebsite String?
  message        String?
  status         LeadStatus @default(NEW)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  proposals Proposal[]

  @@map("leads")
}

// ─── Proposals ────────────────────────────────────────────────────────────────

model Proposal {
  id           String         @id @default(cuid())
  proposalNo   String         @unique
  leadId       String?
  clientName   String
  businessName String
  whatsapp     String?
  packageType  String
  packageLabel String
  addons       Json           @default("[]")
  customItems  Json           @default("[]")
  basePrice    Int
  totalPrice   Int
  timeline     String         @default("2-3 minggu")
  validUntil   DateTime?
  notes        String?        @db.Text
  status       ProposalStatus @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@map("proposals")
}

// ─── Client Portal ────────────────────────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects      Project[]
  invoices      Invoice[]
  tickets       Ticket[]
  subscriptions Subscription[]
  onboardings   OnboardingForm[]
  notifications Notification[]
  hostingRecords HostingRecord[]

  @@map("clients")
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  name        String
  description String?
  status      ProjectStatus @default(DRAFTING)
  startDate   DateTime?
  deadline    DateTime?
  liveUrl     String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  invoiceNo   String        @unique
  description String?
  amount      Int
  lineItems   Json          @default("[]")
  dueDate     DateTime?
  status      InvoiceStatus @default(UNPAID)
  whatsappMsg String?
  tripayRef   String?       @unique
  paymentUrl  String?
  paidAt      DateTime?
  reminderSentAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Ticket {
  id        String       @id @default(cuid())
  clientId  String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String
  senderRole Role
  body       String   @db.Text
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum LeadStatus {
  NEW
  FOLLOWUP
  DEAL
  CLOSED
}

enum ProjectStatus {
  DRAFTING
  DEVELOPMENT
  TESTING
  LIVE
}

enum InvoiceStatus {
  UNPAID
  PAID
  EXPIRED
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum OnboardingStatus {
  PENDING
  REVIEWED
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  clientId  String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, read])
  @@map("notifications")
}

enum NotificationType {
  INVOICE_NEW
  TICKET_REPLY
  PROJECT_STATUS
  HOSTING_EXPIRY
  GENERAL
}

// ─── Hosting & Domain Management ──────────────────────────────────────────────

model HostingRecord {
  id              String        @id @default(cuid())
  clientId        String

  // Domain
  domainName      String
  domainProvider  String?
  domainExpiry    DateTime?

  // Hosting
  hostingProvider String?
  hostingPlan     String?
  hostingExpiry   DateTime?

  // SSL
  sslExpiry       DateTime?

  // Status
  status          HostingStatus @default(ACTIVE)
  notes           String?       @db.Text

  // Notif tracking (cegah spam — 1x per milestone)
  notif30SentAt   DateTime?
  notif14SentAt   DateTime?
  notif7SentAt    DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("hosting_records")
}

enum HostingStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}
