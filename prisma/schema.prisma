generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js required tables ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  client          Client?
  adminPermission AdminPermission?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Content ──────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  articles Article[]

  @@map("categories")
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String        @db.Text
  coverImage  String?
  metaTitle   String?
  metaDesc    String?
  status      ArticleStatus @default(DRAFT)
  publishedAt DateTime?
  scheduledAt DateTime?
  categoryId  String?
  tags        String[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("articles")
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  beforeImage String?
  afterImage  String?
  clientName  String?
  techStack   String[]
  liveUrl     String?
  metrics     String?
  order       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("portfolios")
}

// ─── Onboarding ───────────────────────────────────────────────────────────────

model OnboardingForm {
  id       String           @id @default(cuid())
  clientId String?
  token    String           @unique @default(cuid())
  status   OnboardingStatus @default(PENDING)

  // Step 1 — Bisnis
  businessName   String?
  industryType   String?
  businessDesc   String? @db.Text
  targetAudience String?

  // Step 2 — Website
  websiteType    String?
  referenceUrls  String[]
  featuresWanted String[]
  colorStyle     String?

  // Step 3 — Aset
  logoUrl    String?
  driveLink  String?
  instagram  String?
  facebook   String?
  tiktok     String?
  hasDomain  Boolean @default(false)
  domainName String?

  // Step 4 — Timeline
  deadline DateTime?
  notes    String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@map("onboarding_forms")
}

// ─── Maintenance & Retainer ───────────────────────────────────────────────────

model MaintenancePackage {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int
  features    String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("maintenance_packages")
}

model Subscription {
  id              String             @id @default(cuid())
  clientId        String
  packageId       String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime           @default(now())
  nextBillingDate DateTime
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  client  Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  package MaintenancePackage @relation(fields: [packageId], references: [id])

  @@map("subscriptions")
}

// ─── Site Content ─────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  business  String
  text      String   @db.Text
  rating    Int      @default(5)
  order     Int      @default(0)
  featured  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt

  @@map("site_settings")
}

// ─── Leads / CRM ──────────────────────────────────────────────────────────────

model Lead {
  id              String              @id @default(cuid())
  name            String
  businessName    String
  whatsapp        String
  domain          String?
  currentWebsite  String?
  message         String?
  status          LeadStatus          @default(NEW)
  notes           String?
  lastContactedAt DateTime? // Kapan terakhir dikirim WA broadcast
  waOptInStatus   WhatsAppOptInStatus @default(UNKNOWN)
  waOptInAt       DateTime?
  waOptInSource   String?
  waOptOutAt      DateTime?
  waOptOutReason  String?
  doNotContact    Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  proposals           Proposal[]
  broadcastRecipients BroadcastRecipient[]

  @@map("leads")
}

model LeadFinderSocialScanCache {
  id          String   @id @default(cuid())
  websiteUrl  String   @unique
  socialLinks Json
  status      String
  error       String?
  scannedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scannedAt])
  @@map("lead_finder_social_scan_cache")
}

// ─── Proposals ────────────────────────────────────────────────────────────────

model Proposal {
  id           String         @id @default(cuid())
  proposalNo   String         @unique
  leadId       String?
  clientName   String
  businessName String
  whatsapp     String?
  packageType  String
  packageLabel String
  addons       Json           @default("[]")
  customItems  Json           @default("[]")
  basePrice    Int
  totalPrice   Int
  timeline     String         @default("2-3 minggu")
  validUntil   DateTime?
  notes        String?        @db.Text
  status       ProposalStatus @default(DRAFT)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@map("proposals")
}

// ─── Client Portal ────────────────────────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects       Project[]
  invoices       Invoice[]
  tickets        Ticket[]
  subscriptions  Subscription[]
  onboardings    OnboardingForm[]
  notifications  Notification[]
  hostingRecords HostingRecord[]
  credit         ClientCredit?
  creditTxs      CreditTransaction[]
  proposalTemplates ProposalTemplate[]
  generatedProposals GeneratedProposal[]
  generatedInvoices GeneratedInvoice[]
  proposalBrandKit ProposalBrandKit?
  invoiceBrandKit InvoiceBrandKit?

  @@map("clients")
}

model ClientCredit {
  id        String   @id @default(cuid())
  clientId  String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_credits")
}

model CreditTransaction {
  id          String       @id @default(cuid())
  clientId    String
  amount      Int
  type        CreditTxType
  tool        String?
  description String
  meta        Json?
  createdAt   DateTime     @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

model CreditPackage {
  id          String   @id @default(cuid())
  name        String
  credits     Int
  price       Int
  bonusCredit Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("credit_packages")
}

model ProposalTemplate {
  id          String   @id @default(cuid())
  clientId    String?
  name        String
  category    String
  description String?
  sections    Json
  variables   Json?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client             Client?             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  generatedProposals GeneratedProposal[]

  @@index([clientId])
  @@map("proposal_templates")
}

model GeneratedProposal {
  id           String   @id @default(cuid())
  clientId     String
  templateId   String?
  proposalNo   String?  @unique
  title        String
  prospectName String?
  businessName String?
  whatsapp     String?
  validUntil   DateTime?
  notes        String?
  templateName String?
  design       Json?
  input        Json
  content      Json
  status       String   @default("DRAFT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  template ProposalTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@map("generated_proposals")
}

model GeneratedInvoice {
  id            String   @id @default(cuid())
  clientId      String
  invoiceNo     String   @unique
  templateName   String?
  title         String
  fromName      String
  fromEmail     String?
  fromPhone     String?
  fromAddress   String?
  billToName    String
  billToEmail   String?
  billToPhone   String?
  billToAddress String?
  issueDate     DateTime
  dueDate       DateTime?
  lineItems     Json
  subtotal      Int
  discount      Int      @default(0)
  taxLabel      String?
  taxAmount     Int      @default(0)
  total         Int
  notes         String?  @db.Text
  footer        String?  @db.Text
  design        Json?
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("generated_invoices")
}

model InvoiceBrandKit {
  id             String   @id @default(cuid())
  clientId       String   @unique
  logoUrl        String?
  primaryColor   String   @default("#1d4ed8")
  accentColor    String   @default("#0d9488")
  fontStyle      String   @default("sans")
  layout         String   @default("corporate")
  logoPosition   String   @default("left")
  showLogo       Boolean  @default(true)
  showInvoiceNo  Boolean  @default(true)
  showDueDate    Boolean  @default(true)
  showSender     Boolean  @default(true)
  showRecipient  Boolean  @default(true)
  showFooter     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("invoice_brand_kits")
}

model ProposalBrandKit {
  id             String   @id @default(cuid())
  clientId       String   @unique
  logoUrl        String?
  primaryColor   String   @default("#1e40af")
  accentColor    String   @default("#0d9488")
  fontStyle      String   @default("sans")
  layout         String   @default("corporate")
  logoPosition   String   @default("left")
  showLogo       Boolean  @default(true)
  showProposalNo Boolean  @default(true)
  showDate       Boolean  @default(true)
  showRecipient  Boolean  @default(true)
  showFooter     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("proposal_brand_kits")
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  name        String
  description String?
  status      ProjectStatus @default(DRAFTING)
  startDate   DateTime?
  deadline    DateTime?
  liveUrl     String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Invoice {
  id             String        @id @default(cuid())
  clientId       String
  invoiceNo      String        @unique
  description    String?
  amount         Int
  lineItems      Json          @default("[]")
  dueDate        DateTime?
  status         InvoiceStatus @default(UNPAID)
  whatsappMsg    String?
  tripayRef      String?       @unique
  paymentUrl     String?
  paidAt         DateTime?
  reminderSentAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Ticket {
  id        String       @id @default(cuid())
  clientId  String
  subject   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@map("tickets")
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String
  senderRole Role
  body       String   @db.Text
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum LeadStatus {
  NEW
  FOLLOWUP
  DEAL
  CLOSED
}

enum WhatsAppOptInStatus {
  UNKNOWN
  OPTED_IN
  OPTED_OUT
}

enum ProjectStatus {
  DRAFTING
  DEVELOPMENT
  TESTING
  LIVE
}

enum InvoiceStatus {
  UNPAID
  PAID
  EXPIRED
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum OnboardingStatus {
  PENDING
  REVIEWED
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

enum CreditTxType {
  TOPUP
  USE
  REFUND
  BONUS
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  clientId  String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, read])
  @@map("notifications")
}

enum NotificationType {
  INVOICE_NEW
  TICKET_REPLY
  PROJECT_STATUS
  HOSTING_EXPIRY
  GENERAL
}

// ─── Hosting & Domain Management ──────────────────────────────────────────────

model HostingRecord {
  id       String @id @default(cuid())
  clientId String

  // Domain
  domainName     String
  domainProvider String?
  domainExpiry   DateTime?

  // Hosting
  hostingProvider String?
  hostingPlan     String?
  hostingExpiry   DateTime?

  // SSL
  sslExpiry DateTime?

  // Status
  status HostingStatus @default(ACTIVE)
  notes  String?       @db.Text

  // Notif tracking (cegah spam — 1x per milestone)
  notif30SentAt DateTime?
  notif14SentAt DateTime?
  notif7SentAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("hosting_records")
}

// ─── Broadcast Log ────────────────────────────────────────────────────────────

model BroadcastLog {
  id             String   @id @default(cuid())
  sentAt         DateTime @default(now())
  totalLeads     Int
  sent           Int
  failed         Int
  skipped        Int      @default(0)
  devices        Int      @default(1)
  delayRange     String
  messageSnippet String // first 100 chars of message
  createdAt      DateTime @default(now())

  recipients BroadcastRecipient[]

  @@map("broadcast_logs")
}

model BroadcastRecipient {
  id               String                   @id @default(cuid())
  broadcastId      String
  leadId           String?
  phone            String
  status           BroadcastRecipientStatus @default(QUEUED)
  skipReason       String?
  providerResponse String?                  @db.Text
  messageSnippet   String                   @db.Text
  sentAt           DateTime?
  createdAt        DateTime                 @default(now())

  broadcast BroadcastLog @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  lead      Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([broadcastId])
  @@index([leadId])
  @@index([phone])
  @@map("broadcast_recipients")
}

enum BroadcastRecipientStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
  OPTED_OUT
}

enum HostingStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

// ─── Team Permissions ─────────────────────────────────────────────────────────

model TeamRole {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions      TeamRolePermission[]
  adminAssignments AdminPermission[]

  @@map("team_roles")
}

model TeamRolePermission {
  id     String @id @default(cuid())
  roleId String
  module String // nilai dari VALID_MODULES

  role TeamRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@map("team_role_permissions")
}

model AdminPermission {
  id           String   @id @default(cuid())
  adminId      String   @unique
  roleId       String?
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admin User      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role  TeamRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@map("admin_permissions")
}

model PermissionAuditLog {
  id            String   @id @default(cuid())
  changedBy     String // userId Super Admin
  targetAdminId String?
  targetRoleId  String?
  action        String // ROLE_CREATED, ROLE_UPDATED, dll.
  before        Json
  after         Json
  createdAt     DateTime @default(now())

  @@map("permission_audit_logs")
}

model AiUsageLog {
  id        String   @id @default(cuid())
  feature   String
  model     String
  status    String
  actor     String?
  error     String?  @db.Text
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([feature])
  @@index([status])
  @@index([createdAt])
  @@map("ai_usage_logs")
}
